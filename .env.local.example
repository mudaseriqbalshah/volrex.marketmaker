NEXT_PUBLIC_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CHAIN_ID=1378

# Single RPC URL (legacy / single-node setup).
NEXT_PUBLIC_RPC_URL=https://rpc.volrex.network/

# OR: comma-separated list of RPC URLs to round-robin across for load
# balancing + fallback. If set, this wins over NEXT_PUBLIC_RPC_URL.
# NEXT_PUBLIC_RPC_URLS=https://rpc1.volrex.network/,https://rpc2.volrex.network/

NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_WETH_ADDRESS=

# Optional: after each successful Buy/Sell the MM fires a fire-and-forget
# request at the indexer's /api/cron endpoint so the swap shows up on
# vorlexscan.com within seconds instead of waiting for the next cron tick.
# Leave both unset to skip the hook entirely.
INDEXER_URL=https://vorlexscan.com
INDEXER_CRON_SECRET=
